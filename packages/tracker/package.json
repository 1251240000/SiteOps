{
  "name": "@siteops/tracker",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./browser": {
      "types": "./dist/src/browser.d.ts",
      "import": "./dist/src/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && pnpm build:browser && pnpm copy:browser",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:browser": "vite build",
    "copy:browser": "mkdir -p ../../apps/web/public && cp dist/siteops-tracker.iife.js ../../apps/web/public/tracker.js"
  },
  "devDependencies": {
    "@siteops/eslint-config": "workspace:*",
    "@siteops/tsconfig": "workspace:*",
    "@types/node": "^20.16.13",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "vite": "^7.3.3"
  }
}
