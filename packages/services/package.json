{
  "name": "@siteops/services",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run"
  },
  "dependencies": {
    "@siteops/db": "workspace:*",
    "@siteops/integrations": "workspace:*",
    "@siteops/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "lru-cache": "^11.5.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@siteops/eslint-config": "workspace:*",
    "@siteops/tsconfig": "workspace:*",
    "@types/node": "^20.16.13",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
