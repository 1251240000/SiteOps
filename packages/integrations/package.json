{
  "name": "@siteops/integrations",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@siteops/shared": "workspace:*",
    "cheerio": "^1.0.0"
  },
  "optionalDependencies": {
    "chrome-launcher": "^1.1.2",
    "lighthouse": "^12.2.1",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@siteops/eslint-config": "workspace:*",
    "@siteops/tsconfig": "workspace:*",
    "@types/node": "^20.16.13",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
