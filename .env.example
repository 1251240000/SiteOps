# ---- Runtime ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Database ----
# Host-side connection string used by `pnpm dev` against
# `infra/docker-compose.dev.yml`. In `infra/docker-compose.yml` (prod) the
# DATABASE_URL is composed automatically from POSTGRES_* below and uses the
# in-network hostname `postgres:5432`.
DATABASE_URL=postgres://siteops:siteops@localhost:5432/siteops
POSTGRES_DB=siteops
POSTGRES_USER=siteops
POSTGRES_PASSWORD=siteops
POSTGRES_PORT=5432

# ---- Cache / Queue ----
# Same split as DATABASE_URL: REDIS_URL is for host-side dev; the prod compose
# composes `redis://:${REDIS_PASSWORD}@redis:6379` from REDIS_PASSWORD below.
# Dev defaults to no auth; in prod REDIS_PASSWORD is required.
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Auth.js ----
# openssl rand -base64 32
AUTH_SECRET=replace-me-with-strong-random
# AUTH_URL is auto-inferred in dev; set explicitly in prod
# AUTH_URL=https://siteops.example.com

# ---- Dev server ----
# When accessing `pnpm dev` from a host other than localhost (e.g. a LAN IP
# or an internal hostname), list those origins here so Next.js doesn't warn
# about cross-origin `/_next/*` asset requests. Comma-separated, no scheme.
# Example: NEXT_DEV_ALLOWED_ORIGINS=10.1.1.10,siteops.lan
# NEXT_DEV_ALLOWED_ORIGINS=

# ---- Worker / monitoring (M2) ----
# AES-256-GCM key for alert channel config encryption.
# Either 64 hex chars, 32-byte base64, or any passphrase (PBKDF2-derived).
# Required in production; dev has a hard-coded fallback.
# ALERT_CIPHER_KEY=
# Directories that the worker writes raw audit reports to.
AUDIT_DATA_DIR=/var/lib/siteops/audits
LIGHTHOUSE_DATA_DIR=/var/lib/siteops/lighthouse
# Lighthouse runner: `stub` (default in dev/CI; deterministic placeholder
# scores) or `real` (boots system Chromium via the optional `lighthouse` +
# `chrome-launcher` deps). The prod compose stack sets this to `real`
# automatically; switch to `stub` here only for local dev without Chromium.
# LIGHTHOUSE_RUNNER=stub
# Default per-site uptime check interval, in minutes.
UPTIME_DEFAULT_INTERVAL_MIN=5
# T32 — graceful shutdown drain budget (ms). After SIGTERM/SIGINT the worker
# closes BullMQ workers (which always wait for the in-flight job), then
# drains any extra promises tracked via `shutdownState.track()` for up to
# WORKER_SHUTDOWN_TIMEOUT_MS before forcing exit. Default 30000.
# WORKER_SHUTDOWN_TIMEOUT_MS=30000

# ---- Admin seed (only used on first `pnpm db:seed`) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ---- Prod deploy (infra/docker-compose.yml) ----
# Domain Caddy terminates TLS for. Use `localhost` for a prod-like local run
# (Caddy then serves :80 only, no ACME). Set to a real domain in production.
SITEOPS_DOMAIN=localhost
CADDY_ACME_EMAIL=admin@example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# Optional image overrides for `docker compose -f infra/docker-compose.yml up`
# SITEOPS_WEB_IMAGE=siteops/web:local
# SITEOPS_WORKER_IMAGE=siteops/worker:local

# T49 — pg_dump sidecar (`docker compose --profile backup up -d`). Dumps land
# in the named volume `pg-backup` mounted at /backups inside the sidecar.
# Operational runbook: docs/12-backup-restore.md.
# Number of days to keep .dump files; older ones are pruned after each run.
BACKUP_KEEP_DAYS=14
# Five-field busybox crontab schedule (UTC). Default: 02:00 UTC daily.
# BACKUP_CRON=0 2 * * *
# Run a backup once at sidecar startup (handy for first-boot smoke test).
# BACKUP_RUN_ON_BOOT=false

# ---- External integrations (M3) ----
# All optional — leave blank to skip the corresponding sync. The dashboard's
# Integrations page surfaces which providers are configured.

# T17 — Cloudflare. Token needs `Account.Cloudflare Pages: Read`.
# CF_API_TOKEN=

# T18 — GitHub. PAT with `repo:status, public_repo` (or `repo` for private).
# GH_TOKEN=

# T19 — GA4 + Plausible.
# Service account JSON (raw or base64). Add the SA email as Viewer in GA4
# Admin → Property Access.
# GA4_SERVICE_ACCOUNT_JSON=
# PLAUSIBLE_API_KEY=

# T20 — Search Console (Google OAuth2 web client).
# Redirect URI must match what's registered in the GCP console.
# GSC_OAUTH_CLIENT_ID=
# GSC_OAUTH_CLIENT_SECRET=
# GSC_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/integrations/gsc/callback

# T21 — AdSense (Google OAuth2 web client).
# ADSENSE_ACCOUNT_NAME format: `accounts/pub-XXXXXXXX`.
# ADSENSE_OAUTH_CLIENT_ID=
# ADSENSE_OAUTH_CLIENT_SECRET=
# ADSENSE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/integrations/adsense/callback
# ADSENSE_ACCOUNT_NAME=

# T27 — Webhook receivers (CF Pages Notification API + GitHub Actions).
# Each provider's webhook is *only* exposed when the corresponding secret is
# present; otherwise the route replies 503 `webhook_not_configured`. Use a
# long random string (>= 16 chars; openssl rand -hex 32 works).
# CF_WEBHOOK_SECRET=
# GH_WEBHOOK_SECRET=

# ---- Email notifier (M10/T44) ----
# `disabled` (default) keeps the legacy log-only behaviour so existing
# deployments don't suddenly start sending. Switch to `resend` or `smtp`
# only once the corresponding credentials below are populated; the worker
# raises a precise error on first send if a required var is missing.
#
# DKIM / SPF / DMARC must be configured at the DNS layer (out of scope for
# this app). For Resend, follow https://resend.com/docs/send-with-domains;
# for SMTP, the upstream provider's docs.
EMAIL_PROVIDER=disabled
# EMAIL_FROM=siteops@example.com

# Resend (https://resend.com). API key from dashboard → API Keys.
# RESEND_API_KEY=

# SMTP (any RFC 5321 server: SES, SendGrid, mailgun, self-hosted, ...).
# SMTP_TLS=true forces implicit TLS (port 465); leave unset/false for
# STARTTLS on 587 (nodemailer default behaviour for the chosen port).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_TLS=false
