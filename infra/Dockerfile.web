# syntax=docker/dockerfile:1.7
#
# siteops — web image (Next.js apps/web)
#
# Build context MUST be the repo root, e.g.:
#   docker build -f infra/Dockerfile.web -t siteops/web .
#
# Stages
#   1) deps    — install workspace deps with pnpm (uses lockfile + manifests
#                only, so this layer caches well).
#   2) build   — copy the rest of the repo and run `next build` for
#                `@siteops/web`. `output: 'standalone'` in `next.config.mjs`
#                emits `.next/standalone/` containing a self-sufficient
#                Node bundle plus a minimal `node_modules/`.
#   3) runtime — copy the standalone bundle + `.next/static` into a fresh
#                Node 20 alpine image and run `node server.js`.

ARG NODE_VERSION=20-alpine
ARG PNPM_VERSION=9.12.3
# Build-time mirrors (override to upstream when building outside CN):
#   --build-arg ALPINE_MIRROR=https://dl-cdn.alpinelinux.org/alpine
#   --build-arg NPM_REGISTRY=https://registry.npmjs.org
ARG ALPINE_MIRROR=https://mirrors.aliyun.com/alpine
ARG NPM_REGISTRY=https://registry.npmmirror.com

# -----------------------------------------------------------------------------
# 1) deps
# -----------------------------------------------------------------------------
FROM node:${NODE_VERSION} AS deps
ARG PNPM_VERSION
ARG ALPINE_MIRROR
ARG NPM_REGISTRY
ENV COREPACK_NPM_REGISTRY=${NPM_REGISTRY}
RUN sed -i "s|https\?://dl-cdn.alpinelinux.org/alpine|${ALPINE_MIRROR}|g" /etc/apk/repositories \
 && apk add --no-cache libc6-compat \
 && corepack enable \
 && corepack prepare pnpm@${PNPM_VERSION} --activate \
 && pnpm config set registry "${NPM_REGISTRY}"
WORKDIR /repo

# Root manifests + lockfile
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc* ./

# Workspace package manifests (keep this list in sync with pnpm-workspace.yaml)
COPY apps/web/package.json                  apps/web/package.json
COPY apps/worker/package.json               apps/worker/package.json
COPY packages/db/package.json               packages/db/package.json
COPY packages/services/package.json         packages/services/package.json
COPY packages/integrations/package.json     packages/integrations/package.json
COPY packages/shared/package.json           packages/shared/package.json
COPY packages/config-eslint/package.json    packages/config-eslint/package.json
COPY packages/config-typescript/package.json packages/config-typescript/package.json

RUN --mount=type=cache,id=pnpm,target=/pnpm-store \
    pnpm config set store-dir /pnpm-store \
 && pnpm install --frozen-lockfile

# -----------------------------------------------------------------------------
# 2) build
# -----------------------------------------------------------------------------
FROM deps AS build
WORKDIR /repo

# Bring in the rest of the repo (respecting infra/.dockerignore).
COPY . .

# Build the web workspace and all of its workspace deps (`...` syntax).
RUN pnpm --filter @siteops/web... build

# -----------------------------------------------------------------------------
# 3) runtime
# -----------------------------------------------------------------------------
FROM node:${NODE_VERSION} AS runtime
ARG ALPINE_MIRROR
RUN sed -i "s|https\?://dl-cdn.alpinelinux.org/alpine|${ALPINE_MIRROR}|g" /etc/apk/repositories \
 && apk add --no-cache curl tini \
 && addgroup -g 1001 -S nodejs \
 && adduser  -u 1001 -S nextjs -G nodejs
WORKDIR /app

# `next build` with `output: 'standalone'` emits a self-sufficient bundle.
# The static assets directory has to be copied separately because Next.js
# leaves it outside the standalone bundle (intended for CDN offload).
COPY --from=build --chown=nextjs:nodejs /repo/apps/web/.next/standalone /app
COPY --from=build --chown=nextjs:nodejs /repo/apps/web/.next/static     /app/apps/web/.next/static
# `public/` is optional; copy it conditionally so the build doesn't fail
# when the directory is absent (it currently is until T07).
COPY --from=build --chown=nextjs:nodejs /repo/apps/web/public            /app/apps/web/public

USER nextjs

ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0

EXPOSE 3000

HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=5 \
  CMD curl -fsS "http://127.0.0.1:${PORT}/healthz" || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "/app/apps/web/server.js"]
