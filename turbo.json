{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", ".env.example"],
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "CI",
    "TURBO_TELEMETRY_DISABLED",
    "NEXT_TELEMETRY_DISABLED"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["DATABASE_URL", "REDIS_URL", "AUTH_SECRET", "AUTH_URL", "LOGIN_RATE_LIMIT_PER_MIN"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "REDIS_URL", "AUTH_SECRET"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "REDIS_URL", "AUTH_SECRET"],
      "outputs": ["coverage/**"]
    },
    "i18n:check": {
      "inputs": ["messages/**/*.json", "scripts/check-i18n-keys.mjs"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "AUTH_SECRET",
        "AUTH_URL",
        "LOGIN_RATE_LIMIT_PER_MIN",
        "ALERT_CIPHER_KEY",
        "AUDIT_DATA_DIR",
        "LIGHTHOUSE_DATA_DIR",
        "UPTIME_DEFAULT_INTERVAL_MIN",
        "CF_API_TOKEN",
        "GH_TOKEN",
        "GA4_SERVICE_ACCOUNT_JSON",
        "PLAUSIBLE_API_KEY",
        "GSC_OAUTH_CLIENT_ID",
        "GSC_OAUTH_CLIENT_SECRET",
        "GSC_OAUTH_REDIRECT_URI",
        "ADSENSE_OAUTH_CLIENT_ID",
        "ADSENSE_OAUTH_CLIENT_SECRET",
        "ADSENSE_OAUTH_REDIRECT_URI",
        "ADSENSE_ACCOUNT_NAME"
      ]
    }
  }
}
